# OpenRouter (https://openrouter.ai — 무료 :free 모델)
OPENROUTER_API_KEY=
# 실패 시 여러 모델 시도 대신 1~2개만 사용 (한도 절약, 기본 2)
OPENROUTER_MAX_MODEL_ATTEMPTS=2
# 우선 사용할 무료 모델 (Vision). 예: google/gemini-2.0-flash-exp:free
OPENROUTER_PREFERRED_FREE_MODEL=
# true 시 API 없이 로컬 데모 분석 (개발·테스트 전용)
ANALYZE_MOCK_MODE=false
# OpenRouter 실패 시 데모 분석으로 자동 대체 (기본 false — 실제 분석만 사용)
ANALYZE_FALLBACK_MOCK=false
# Vision 분석 우선 모델 (유료 가능). 예: google/gemini-2.5-flash
OPENROUTER_VISION_MODEL=
# 무료 모델 실패 시 저가 유료 Vision 모델 시도 (크레딧 필요)
OPENROUTER_ALLOW_PAID_MODELS=true
# AI Hub (https://aihub.or.kr — aihubshell API key, 선택)
AIHUB_API_KEY=
AIHUB_SHELL_PATH=
AIHUB_BASH_PATH=
AIHUB_DOWNLOAD_DIR=

# App
NEXT_PUBLIC_APP_URL=http://localhost:50006

# Supabase (https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=
# 또는 기존 프로젝트 변수명
NEXT_PUBLIC_STORYSUPABASE_URL=
# 서버 API 전용 — GitHub/Vercel에 커밋하지 마세요
SUPABASE_SERVICE_ROLE_KEY=
# 또는 Supabase 새 secret key (sb_secret_...)
SUPABASE_SECRET_KEY=
