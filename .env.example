# OpenRouter (https://openrouter.ai — 무료 :free 모델만 사용)
OPENROUTER_API_KEY=
# 시도할 무료 모델 수 (기본 12, 최대 20)
OPENROUTER_MAX_MODEL_ATTEMPTS=12
# 우선 시도할 무료 Vision 모델 (:free 필수). 쉼표로 여러 개 가능
OPENROUTER_PREFERRED_FREE_MODEL=qwen/qwen2.5-vl-32b-instruct:free,google/gemini-2.0-flash-exp:free
# 데모·목업 분석 비활성 (false 유지)
ANALYZE_MOCK_MODE=false
ANALYZE_FALLBACK_MOCK=false
# AI Hub (https://aihub.or.kr — aihubshell API key, 선택)
AIHUB_API_KEY=
AIHUB_SHELL_PATH=
AIHUB_BASH_PATH=
AIHUB_DOWNLOAD_DIR=

# App
NEXT_PUBLIC_APP_URL=http://localhost:50006

# Supabase (https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=
# 또는 기존 프로젝트 변수명
NEXT_PUBLIC_STORYSUPABASE_URL=
# 서버 API 전용 — GitHub/Vercel에 커밋하지 마세요
SUPABASE_SERVICE_ROLE_KEY=
# 또는 Supabase 새 secret key (sb_secret_...)
SUPABASE_SECRET_KEY=
