# OpenRouter (https://openrouter.ai — 무료 :free 모델)
OPENROUTER_API_KEY=
# 실패 시 여러 모델 시도 대신 1~2개만 사용 (한도 절약, 기본 2)
OPENROUTER_MAX_MODEL_ATTEMPTS=2
# 우선 사용할 무료 모델 (Vision). 예: google/gemini-2.0-flash-exp:free
OPENROUTER_PREFERRED_FREE_MODEL=
# true 시 API 없이 로컬 데모 분석 (한도 소진·개발용)
ANALYZE_MOCK_MODE=false
# OpenRouter 실패 시 데모 분석으로 자동 대체 (기본 true, 끄려면 false)
ANALYZE_FALLBACK_MOCK=true
# AI Hub (https://aihub.or.kr — aihubshell API key, 선택)
AIHUB_API_KEY=
AIHUB_SHELL_PATH=
AIHUB_BASH_PATH=
AIHUB_DOWNLOAD_DIR=

# App
NEXT_PUBLIC_APP_URL=http://localhost:50006
