{
  "name": "autodealer-copilot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 50006",
    "dev:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev -p 50006",
    "build": "next build",
    "vercel-build": "node scripts/setup-aihubshell.mjs && next build",
    "start": "next start -p 50006",
    "docker:build": "docker build -t autodealer-copilot .",
    "docker:up": "docker compose up -d --build",
    "lint": "next lint",
    "aihub:setup": "node scripts/setup-aihubshell.mjs"
  },
  "dependencies": {
    "@vercel/blob": "0.27.3",
    "clsx": "2.1.1",
    "lucide-react": "0.511.0",
    "next": "15.5.18",
    "react": "19.1.7",
    "react-dom": "19.1.7",
    "tailwind-merge": "3.3.0",
    "zod": "3.25.42"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.1",
    "@tailwindcss/postcss": "4.1.8",
    "@types/node": "22.15.29",
    "@types/react": "19.1.6",
    "@types/react-dom": "19.1.5",
    "eslint": "9.28.0",
    "eslint-config-next": "15.5.18",
    "tailwindcss": "4.1.8",
    "typescript": "5.8.3"
  }
}
